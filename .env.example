DATABASE_URL=
# Optional aliases. DATABASE_URL takes precedence.
POSTGRES_URL=
SUPABASE_DB_URL=

# Public preview: set 1 in public Vercel env.
# Internal admin env: set 0 and combine with GAMETOK_INTERNAL_ADMIN=1.
GAMETOK_READ_ONLY_PREVIEW=1

# Set to 1 only in local dev or internal admin deployments.
GAMETOK_INTERNAL_ADMIN=0

# Required for Vercel Cron to call the internal sync route.
CRON_SECRET=

# Optional YouTube Analytics OAuth for authorized channels.
YOUTUBE_CLIENT_ID=
YOUTUBE_REDIRECT_URI=
